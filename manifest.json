{
    "name": "NoteWizard",
    "author": "Sashank",
    "version": "0.1.0",
    "description": "Save Note Text from a YT Snapshot",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "scripts" : ["popup.js"],
    "content_scripts": [
        {
            "matches": [
                "https://*.youtube.com/*"
            ],
            "js": [
                "contentScript.js",
                "cropper_proj.js",
                "cropper_proj2.js",
                "jquery.min.js",
                "croppie.js",
                "cropper.min.js"
            ]
        }
    ],
    "action": {
        "default_title": "NoteWizard",
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icon16.jpeg",
        "48": "icon48.jpeg",
        "128": "icon128.jpeg"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "edit.png",
                "cropper_proj.js",
                "cropper_proj2.js",
                "cropper_proj.css",
                "jquery.min.js",
                "croppie.js",
                "croppie.css",
                "cropper.min.js"
            ],
            "matches": [
                "https://*.youtube.com/*"
            ]
        }
    ],
    "manifest_version": 3
}